# QuickChat Environment Configuration
# Copy to .env and fill in values:  cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────
# "ollama" for local development, "groq" for cloud / HF Spaces
LLM_PROVIDER=ollama

# Ollama settings (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Groq settings (when LLM_PROVIDER=groq)
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ── ChromaDB ──────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./data/chroma

# ── Server ────────────────────────────────────────────────────────────
SERVER_PORT=8000

# ── Voice Agent (Twilio ConversationRelay) ────────────────────────────
# Public hostname for WebSocket URL in TwiML (e.g. your-domain.ngrok.io)
# VOICE_WS_HOST=
PHONE_MAPPING_PATH=config/phone_mapping.json
CR_VOICE=Google.en-US-Standard-J
CR_LANGUAGE=en-US
CR_TRANSCRIPTION_PROVIDER=deepgram
CR_SPEECH_MODEL=nova-3
CR_TTS_PROVIDER=google
